# Postgres connection (matches docker-compose.yml)
DATABASE_URL=postgres://birdseye:birdseye@localhost:5432/birdseye

# OpenAI — required for community notes + moderation.
# If unset, notes/moderation degrade gracefully (no note, content allowed).
OPENAI_API_KEY=

# Resend — required to actually email OTP codes.
# If unset, OTP codes are printed to the server console (dev mode).
RESEND_API_KEY=
EMAIL_FROM=BirdsEye <onboarding@resend.dev>

# Public origin, used for adapter-node in production
ORIGIN=http://localhost:5173

# Runtime upload storage for post header images
UPLOAD_DIR=data/uploads
